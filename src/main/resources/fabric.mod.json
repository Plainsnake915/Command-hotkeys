{
	"schemaVersion": 1,
	"id": "hotcmds",
	"version": "1.0.1",
	"name": "Command Hotkeys",
	"description": "Bind a key to any command you want. /hotcmds to open menu",
	"authors": [
		"Plain_snake915"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/hotcmds/cmd icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.hotcmds.Hotcmds"
		],
		"client": [
			"com.hotcmds.HotcmdsClient"
		],
		"modmenu": [
			"com.hotcmds.ModMenuIntegration"
		]
	},
	"mixins": [
		"hotcmds.mixins.json",
		{
			"config": "hotcmds.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": "~1.21.5",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"com.google.code.gson:gson": "2.11.0",
		"modmenu": ">=14.0.0-rc.2",
		"another-mod": "*"

	}
}